# Copy to .env and fill in real values. .env is gitignored.

# ngrok (get a token at https://dashboard.ngrok.com)
NGROK_AUTHTOKEN=your_ngrok_authtoken

# Postgres
POSTGRES_USER=stonewall
POSTGRES_PASSWORD=change_me_local_dev
POSTGRES_DB=stonewall
DATABASE_URL=postgresql+psycopg://stonewall:change_me_local_dev@db:5432/stonewall

# Site basic auth (nginx gate for the whole app)
BASIC_AUTH_USER=builder
BASIC_AUTH_PASS=change_me_local_dev

# Backend
IMAGE_DIR=/data/images
